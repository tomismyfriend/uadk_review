From: Debug Patch for hisi_zip kernel panic
Subject: [DEBUG] Add diagnostic code for hisi_zip insmod kernel panic

This patch adds comprehensive debugging to verify the root cause analysis:
1. Check SQE residual data when creating QP
2. Add safety checks in callback to prevent crash
3. Detect spurious/stale completion interrupts
4. Log critical state transitions

Signed-off-by: Debug Analysis

---
diff --git a/drivers/crypto/hisilicon/qm.c b/drivers/crypto/hisilicon/qm.c
index xxx..xxx 100644
--- a/drivers/crypto/hisilicon/qm.c
+++ b/drivers/crypto/hisilicon/qm.c
@@ -2155,6 +2155,32 @@ static struct hisi_qp *qm_create_qp_nolock(struct hisi_qm *qm, u8 alg_type,

 	qp = &qm->qp_array[qp_id];
 	hisi_qm_unset_hw_reset(qp);
+
+	/* DEBUG: Check SQE residual data before clearing CQE */
+	{
+		void *sqe_base = qp->sqe;
+		u32 sqe_size = qm->sqe_size;
+		u16 sq_depth = qp->sq_depth;
+		int i;
+
+		for (i = 0; i < sq_depth; i++) {
+			u32 *sqe_dw26 = (u32 *)(sqe_base + i * sqe_size + 104); /* dw26 offset */
+			u32 *sqe_dw27 = (u32 *)(sqe_base + i * sqe_size + 108); /* dw27 offset */
+			u64 tag = (u64)*sqe_dw26 | ((u64)*sqe_dw27 << 32);
+
+			if (tag != 0) {
+				dev_err(&qm->pdev->dev,
+					"[DEBUG] QP%u SQE[%d] has residual tag data! "
+					"dw26=0x%08x, dw27=0x%08x, tag=0x%016llx\n",
+					qp_id, i, *sqe_dw26, *sqe_dw27, tag);
+			}
+		}
+	}
+
+	/* DEBUG: Clear SQE to verify if residual data causes the crash */
+	memset(qp->sqe, 0, qm->sqe_size * qp->sq_depth);
+	dev_info(&qm->pdev->dev, "[DEBUG] QP%u SQE cleared (%u entries, size=%u)\n",
+		 qp_id, qp->sq_depth, qm->sqe_size);
+
 	memset(qp->cqe, 0, sizeof(struct qm_cqe) * qp->cq_depth);

 	qp->event_cb = NULL;
@@ -1052,10 +1078,27 @@ static void qm_poll_req_cb(struct hisi_qp *qp)
 {
 	struct qm_cqe *cqe = qp->cqe + qp->qp_status.cq_head;
 	struct hisi_qm *qm = qp->qm;
+	int used_count = atomic_read(&qp->qp_status.used);

-	while (QM_CQE_PHASE(cqe) == qp->qp_status.cqc_phase) {
+	/* DEBUG: Check if this is a spurious/stale interrupt */
+	if (used_count == 0 && QM_CQE_PHASE(cqe) == qp->qp_status.cqc_phase) {
+		dev_err(&qm->pdev->dev,
+			"[DEBUG] QP%u: SPURIOUS interrupt detected! "
+			"used=%d, cqe_phase=%d, expected_phase=%d, "
+			"sq_head=%u\n",
+			qp->qp_id, used_count, QM_CQE_PHASE(cqe),
+			qp->qp_status.cqc_phase, le16_to_cpu(cqe->sq_head));
+		/* Skip processing to avoid crash from stale data */
+		goto skip_spurious;
+	}
+
+	while (QM_CQE_PHASE(cqe) == qp->qp_status.cqc_phase) {
 		dma_rmb();
+
+		dev_dbg(&qm->pdev->dev,
+			"[DEBUG] QP%u: processing CQE, sq_head=%u, used=%d\n",
+			qp->qp_id, le16_to_cpu(cqe->sq_head), used_count);
+
 		qp->req_cb(qp, qp->sqe + qm->sqe_size *
 			   le16_to_cpu(cqe->sq_head));
 		qm_cq_head_update(qp);
@@ -1067,6 +1110,10 @@ static void qm_poll_req_cb(struct hisi_qp *qp)

 	/* set c_flag */
 	qm_db(qm, qp->qp_id, QM_DOORBELL_CMD_CQ, qp->qp_status.cq_head, 1);
+
+skip_spurious:
+	dev_dbg(&qm->pdev->dev, "[DEBUG] QP%u poll completed, used=%d\n",
+		qp->qp_id, atomic_read(&qp->qp_status.used));
 }

 static void qm_work_process(struct work_struct *work)
@@ -1276,6 +1323,8 @@ static void qm_init_qp_status(struct hisi_qp *qp)
 	qp_status->sq_tail = 0;
 	qp_status->cq_head = 0;
 	qp_status->cqc_phase = true;
+
+	pr_info("[DEBUG] QP%u status initialized: cqc_phase=1\n", qp->qp_id);
 	atomic_set(&qp_status->used, 0);
 	atomic_set(&qp_status->complete_task, 0);
 }
diff --git a/drivers/crypto/hisilicon/zip/zip_crypto.c b/drivers/crypto/hisilicon/zip/zip_crypto.c
index xxx..xxx 100644
--- a/drivers/crypto/hisilicon/zip/zip_crypto.c
+++ b/drivers/crypto/hisilicon/zip/zip_crypto.c
@@ -309,9 +309,49 @@ static void hisi_zip_acomp_cb(struct hisi_qp *qp, void *data)
 {
 	struct hisi_zip_sqe *sqe = data;
 	struct hisi_zip_req *req = (struct hisi_zip_req *)GET_REQ_FROM_SQE(sqe);
-	struct hisi_zip_qp_ctx *qp_ctx = req->qp_ctx;
-	const struct hisi_zip_sqe_ops *ops = qp_ctx->ctx->ops;
-	struct hisi_zip_dfx *dfx = &qp_ctx->zip_dev->dfx;
+	struct hisi_zip_qp_ctx *qp_ctx;
+	const struct hisi_zip_sqe_ops *ops;
+	struct hisi_zip_dfx *dfx;
+
+	/* DEBUG: Comprehensive safety checks before dereferencing */
+
+	/* Check 1: req pointer from SQE */
+	if (!req) {
+		dev_err(&qp->qm->pdev->dev,
+			"[DEBUG] QP%u hisi_zip_acomp_cb: req is NULL! "
+			"dw26=0x%08x, dw27=0x%08x, sqe_addr=%p\n",
+			qp->qp_id, sqe->dw26, sqe->dw27, sqe);
+		return;
+	}
+
+	/* Check 2: req pointer validity (kernel address range) */
+	if (IS_ERR_VALUE((unsigned long)req)) {
+		dev_err(&qp->qm->pdev->dev,
+			"[DEBUG] QP%u hisi_zip_acomp_cb: req is invalid pointer! "
+			"req=%p (ERR), dw26=0x%08x, dw27=0x%08x\n",
+			qp->qp_id, req, sqe->dw26, sqe->dw27);
+		return;
+	}
+
+	/* Check 3: Check if req appears to be in valid kernel memory range */
+	if ((unsigned long)req < 0xffff000000000000UL) {
+		dev_err(&qp->qm->pdev->dev,
+			"[DEBUG] QP%u hisi_zip_acomp_cb: req outside kernel range! "
+			"req=%p, dw26=0x%08x, dw27=0x%08x\n",
+			qp->qp_id, req, sqe->dw26, sqe->dw27);
+		return;
+	}
+
+	/* Check 4: qp_ctx field */
+	if (!req->qp_ctx) {
+		dev_err(&qp->qm->pdev->dev,
+			"[DEBUG] QP%u hisi_zip_acomp_cb: req->qp_ctx is NULL! "
+			"req=%p, req_id=%u, req->req=%p\n",
+			qp->qp_id, req, req->req_id, req->req);
+		return;
+	}
+
+	/* All checks passed, proceed with normal processing */
+	qp_ctx = req->qp_ctx;
+	ops = qp_ctx->ctx->ops;
+	dfx = &qp_ctx->zip_dev->dfx;
+
 	struct device *dev = &qp->qm->pdev->dev;
 	struct acomp_req *acomp_req = req->req;
 	int err = 0;
@@ -321,6 +361,9 @@ static void hisi_zip_acomp_cb(struct hisi_qp *qp, void *data)
 	status = ops->get_status(sqe);
 	if (unlikely(status != 0 && status != HZIP_NC_ERR)) {
 		dev_err(dev, "%scompress fail in qp%u: %u, output: %u\n",
+			/* DEBUG: log the request details on error */
+			dev_err(dev, "[DEBUG] Error details: req=%p, req_id=%u, "
+				"qp_ctx=%p, status=%u\n", req, req->req_id, qp_ctx, status);
 			(qp->alg_type == 0) ? "" : "de", qp->qp_id, status,
 			sqe->produced);
 		atomic64_inc(&dfx->err_bd_cnt);
@@ -143,6 +186,11 @@ static struct hisi_zip_req *hisi_zip_create_req(struct hisi_zip_qp_ctx *qp_ctx,

 	req_cache = q + req_id;
 	req_cache->req_id = req_id;
+
+	/* DEBUG: Log request creation */
+	dev_dbg(&qp_ctx->qp->qm->pdev->dev,
+		"[DEBUG] QP%u created req: req_cache=%p, req_id=%u, qp_ctx=%p\n",
+		qp_ctx->qp->qp_id, req_cache, req_id, qp_ctx);
+
 	req_cache->req = req;
 	req_cache->qp_ctx = qp_ctx;

@@ -215,6 +263,10 @@ static void hisi_zip_fill_tag(struct hisi_zip_sqe *sqe, struct hisi_zip_req *req
 {
 	sqe->dw26 = lower_32_bits((u64)req);
 	sqe->dw27 = upper_32_bits((u64)req);
+
+	/* DEBUG: Log tag filling */
+	pr_debug("[DEBUG] fill_tag: sqe=%p, req=%p, dw26=0x%08x, dw27=0x%08x\n",
+		 sqe, req, sqe->dw26, sqe->dw27);
 }

 static void hisi_zip_fill_sqe(struct hisi_zip_ctx *ctx, struct hisi_zip_sqe *sqe,
@@ -280,6 +332,12 @@ static int hisi_zip_do_work(struct hisi_zip_qp_ctx *qp_ctx,
 		return -EINVAL;

 	req->hw_src = hisi_acc_sg_buf_map_to_hw_sgl(dev, a_req->src, pool,
+
+	/* DEBUG: Log before sending */
+	dev_dbg(dev, "[DEBUG] QP%u sending: req=%p, req_id=%u, "
+		 "sq_tail=%u, used=%d\n",
+		 qp->qp_id, req, req->req_id, qp->qp_status.sq_tail,
+		 atomic_read(&qp->qp_status.used));
+
 						    req->req_id << 1, &req->dma_src,
 						    DMA_TO_DEVICE);
 	if (IS_ERR(req->hw_src)) {
@@ -539,6 +597,10 @@ static void hisi_zip_set_acomp_cb(struct hisi_zip_ctx *ctx,
 	int i;

 	for (i = 0; i < HZIP_CTX_Q_NUM; i++)
+	/* DEBUG: Log callback registration */
+	dev_info(&ctx->qp_ctx[i].qp->qm->pdev->dev,
+		 "[DEBUG] QP%u registered callback hisi_zip_acomp_cb\n",
+		 ctx->qp_ctx[i].qp->qp_id);
+
 		ctx->qp_ctx[i].qp->req_cb = fn;
 }

@@ -574,6 +636,15 @@ static int hisi_zip_acomp_init(struct crypto_acomp *tfm)
 	}

 	hisi_zip_set_acomp_cb(ctx, hisi_zip_acomp_cb);
+
+	/* DEBUG: Log successful initialization */
+	dev_info(dev,
+		 "[DEBUG] hisi_zip_acomp_init completed: ctx=%p, "
+		 "comp_qp=%p (id=%u), decomp_qp=%p (id=%u)\n",
+		 ctx,
+		 ctx->qp_ctx[HZIP_QPC_COMP].qp, ctx->qp_ctx[HZIP_QPC_COMP].qp->qp_id,
+		 ctx->qp_ctx[HZIP_QPC_DECOMP].qp, ctx->qp_ctx[HZIP_QPC_DECOMP].qp->qp_id);
+

 	return 0;

diff --git a/drivers/crypto/hisilicon/zip/zip.h b/drivers/crypto/hisilicon/zip/zip.h
index xxx..xxx 100644
--- a/drivers/crypto/hisilicon/zip/zip.h
+++ b/drivers/crypto/hisilicon/zip/zip.h
@@ -32,6 +32,15 @@ struct hisi_zip_sqe {
 	u32 dw13;
 	u32 dest_avail_out;
 	u32 dw15;
+
+	/* DEBUG: Add comments for tag field offsets */
+	/*
+	 * dw26: lower 32 bits of request pointer (tag)
+	 * dw27: upper 32 bits of request pointer (tag)
+	 * These are used by GET_REQ_FROM_SQE macro to recover the request
+	 * struct pointer from SQE. Stale data here can cause kernel panic.
+	 */
+
 	u32 dw16;
 	u32 dw17;
 	u32 source_addr_l;